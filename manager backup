async function searchWarrants() {
  var query = document.getElementById('searchQuery').value.trim();
  if (!query) { showToast('กรุณากรอกข้อมูลค้นหาก่อน'); return; }
  var searchBtn = document.getElementById('searchBtn');
  var searchLoading = document.getElementById('searchLoading');
  searchBtn.disabled = true;
  searchLoading.classList.add('show');
  try {
    var searchType = /^\d{13}$/.test(query) ? "id13" : "name";
    var result = await callGas("searchDB", { keyword: query, searchType: searchType });
    var warrants = result.data || [];
    searchLoading.classList.remove('show');
    searchBtn.disabled = false;
    if (warrants.length === 0) { alert("ไม่พบข้อมูลหมายจับในระบบ"); return; }
    var defendantName = warrants[0].defendantName;
    currentSearchedDefendant = { defendantName: defendantName, warrants: warrants };
    document.getElementById('searchedDefendantName').innerText = defendantName;
    var listDiv = document.getElementById('warrantsCheckboxList');
    listDiv.innerHTML = '';
    warrants.forEach(function(w, idx) {
      var canSelect = (w.status === 'ต้องการตัว' || w.status === '');
      var div = document.createElement('div');
      div.className = "checkbox-item" + (canSelect ? "" : " disabled");
      div.innerHTML = '<input type="checkbox" id="chk-' + idx + '" value="' + esc(w.warrantNumber) + '" data-detail="' + esc(w.charge) + '" ' + (canSelect ? 'checked' : '') + ' ' + (canSelect ? '' : 'disabled') + '><label for="chk-' + idx + '" style="' + (canSelect ? '' : 'cursor:not-allowed;') + '"><span class="warrant-no"><span>' + esc(w.warrantNumber) + '</span>' + (w.status ? '<span class="warrant-status-tag">' + esc(w.status) + '</span>' : '') + '</span><span class="warrant-detail">' + esc(w.charge) + '</span></label>';
      listDiv.appendChild(div);
    });
    document.getElementById('searchResultsSection').classList.remove('hidden');
    document.getElementById('warrantForm').classList.remove('hidden');
  } catch (err) {
    searchLoading.classList.remove('show');
    searchBtn.disabled = false;
    showToast("การค้นหาล้มเหลว: " + (err.message || "กรุณาลองใหม่"));
  }
}

function handleFormSubmit(e) {
  e.preventDefault();
  if (isProcessing) return;
  var selected = [];
  if (currentSearchedDefendant) {
    currentSearchedDefendant.warrants.forEach(function(w, idx) {
      var chk = document.getElementById('chk-' + idx);
      if (chk && chk.checked) selected.push({ warrantNo: w.warrantNumber, warrantDetail: w.charge });
    });
  }
  if (selected.length === 0) { alert('กรุณาเลือกหมายจับอย่างน้อย 1 รายการ'); return; }
  var reason = document.getElementById('endReason').value;
  var proposed = document.getElementById('proposedTo').value;
  if (!reason) { alert('กรุณาเลือกเหตุ'); return; }
  if (!proposed) { alert('กรุณาเลือกผู้พิพากษา'); return; }
  var arrestTeam = document.getElementById('arrestTeam').value;
  var reasonDetail = document.getElementById('reasonDetail').value;
  pendingDataToSave = {
    defendantName: currentSearchedDefendant.defendantName,
    selectedWarrants: selected,
    endReason: reason,
    reasonDetail: (reason === 'อื่น ๆ') ? reasonDetail : (reason === 'ส่งตัว' ? arrestTeam : ''),
    arrestTeam: (reason === 'ส่งตัว') ? arrestTeam : '',
    proposedTo: proposed
  };
  document.getElementById('confirmDefendant').innerText = pendingDataToSave.defendantName;
  document.getElementById('confirmCaseStatus').innerText = 'เสนอศาล';
  document.getElementById('confirmReason').innerText = reason;
  document.getElementById('confirmReasonDetail').innerText = pendingDataToSave.reasonDetail ? '(' + pendingDataToSave.reasonDetail + ')' : '';
  var list = document.getElementById('confirmWarrantsList');
  list.innerHTML = '';
  selected.forEach(function(w) { var b = document.createElement('div'); b.className = "warrant-badge-sm"; b.innerHTML = '<span class="no">' + esc(w.warrantNo) + '</span><span class="det">' + esc(w.warrantDetail) + '</span>'; list.appendChild(b); });
  openConfirmModal();
}

function doConfirmSave() {
  if (isProcessing || !pendingDataToSave) return;
  closeModal('confirmModal');
  saveProcessRecord(pendingDataToSave);
}

async function saveProcessRecord(data) {
  if (isProcessing) return;
  isProcessing = true;
  showLoading(true);
  try {
    var result = await callGas("saveDB", { action: "addProcess", data: data });
    showToast('บันทึกรายการ ' + (result.count || data.selectedWarrants.length) + ' รายการสำเร็จ');
    pendingDataToSave = null;
    closeFormModal();
    setTimeout(function() { loadDashboard(); }, 200);
  } catch (err) {
    showToast("บันทึกล้มเหลว: " + (err.message || "กรุณาลองใหม่"));
  } finally {
    isProcessing = false;
    showLoading(false);
  }
}

// =============================================================
// Toast
// =============================================================
function showToast(text) {
  var toast = document.getElementById('toast');
  document.getElementById('toastText').innerText = text;
  toast.classList.add('show');
  setTimeout(function() { toast.classList.remove('show'); }, 4000);
}

// =============================================================
// Init
// =============================================================
showLoading(true);
loadDashboard().finally(function() { showLoading(false); });
</script>
</body>
</html>
