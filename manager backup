<script>
// =============================================================
// CONFIG
// =============================================================
var CONFIG = {
  GAS_URL: "https://script.google.com/macros/s/AKfycbxQFqutUu9urZnhFO-OuKkIU3NYmRwhaFP8l-I9h6XiT33p8Yluv5O9so6GMHW0ZRk/exec",
  TIMEOUT: 20000,
  RETRY_DELAYS: [500, 1000, 2000]
};

var masterItems = [];
var currentTab = 'active';
var currentSearchedDefendant = null;
var pendingActionCallback = null;
var pendingDataToSave = null;
var isProcessing = false;
var isLoadingDashboard = false;

// =============================================================
// API Gateway (with AbortController + Retry)
// =============================================================
async function callGas(fn, payload, retryCount) {
  if (retryCount === undefined) retryCount = 0;
  var controller = new AbortController();
  var timer = setTimeout(function() { controller.abort(); }, CONFIG.TIMEOUT);
  try {
    var res = await fetch(CONFIG.GAS_URL, {
      method: 'POST',
      headers: { 'Content-Type': 'text/plain;charset=utf-8' },
      body: JSON.stringify({ fn: fn, payload: payload || {} }),
      signal: controller.signal
    });
    clearTimeout(timer);
    var json = await res.json();
    if (json && json.success === false) {
      throw new Error(json.error || "ระบบปฏิเสธคำขอ");
    }
    return json;
  } catch (err) {
    clearTimeout(timer);
    if (err.name === 'AbortError') {
      if (retryCount < CONFIG.RETRY_DELAYS.length) {
        var delay = CONFIG.RETRY_DELAYS[retryCount];
        console.log("Timeout, retry " + (retryCount+1) + "/" + CONFIG.RETRY_DELAYS.length + " in " + delay + "ms");
        await new Promise(function(r) { setTimeout(r, delay); });
        return callGas(fn, payload, retryCount + 1);
      }
      throw new Error("การเชื่อมต่อหมดเวลา กรุณาลองใหม่");
    }
    if (retryCount < CONFIG.RETRY_DELAYS.length) {
      var delay = CONFIG.RETRY_DELAYS[retryCount];
      console.log("Error, retry " + (retryCount+1) + "/" + CONFIG.RETRY_DELAYS.length + " in " + delay + "ms");
      await new Promise(function(r) { setTimeout(r, delay); });
      return callGas(fn, payload, retryCount + 1);
    }
    throw err;
  }
}

// =============================================================
// Loading
// =============================================================
function showLoading(show) {
  var el = document.getElementById('loadingOverlay');
  if (show) el.classList.add('show');
  else el.classList.remove('show');
}

// =============================================================
// Modal Open / Close
// =============================================================
function openModal(id) {
  var el = document.getElementById(id);
  el.classList.remove('hidden');
  el.classList.add('show');
}
function closeModal(id) {
  var el = document.getElementById(id);
  el.classList.remove('show');
  el.classList.add('hidden');
}
function openConfirmModal() { openModal('confirmModal'); }

// =============================================================
// Load Dashboard (with isLoading flag)
// =============================================================
async function loadDashboard() {
  if (isLoadingDashboard) return;
  isLoadingDashboard = true;
  try {
    var result = await callGas("callList", {});
    masterItems = result.data || [];
    renderDashboard();
  } catch (err) {
    showToast("ไม่สามารถโหลดข้อมูล: " + (err.message || "การเชื่อมต่อล้มเหลว"));
  } finally {
    isLoadingDashboard = false;
  }
}

// =============================================================
// Tab Switching
// =============================================================
function switchTab(tabName) {
  currentTab = tabName;
  document.getElementById('tabActive').className = "tab-btn" + (tabName === 'active' ? " active" : "");
  document.getElementById('tabPending').className = "tab-btn" + (tabName === 'pending' ? " active" : "");
  renderDashboard();
}

// =============================================================
// Render Dashboard (with DocumentFragment + Event Delegation)
// =============================================================
function renderDashboard() {
  var list = document.getElementById('itemsList');
  var tableCard = document.getElementById('tableCard');
  var emptyState = document.getElementById('emptyState');

  var countActive = masterItems.filter(function(i) { return i.caseStatus === 'เสนอศาล'; }).length;
  var countPending = masterItems.filter(function(i) { return i.caseStatus === 'รอส่งต่อสำนวน' || i.caseStatus === 'รายงานแล้ว'; }).length;

  document.getElementById('countActive').innerText = countActive;
  document.getElementById('countPending').innerText = countPending;

  var filtered = [];
  if (currentTab === 'active') {
    filtered = masterItems.filter(function(i) { return i.caseStatus === 'เสนอศาล'; });
  } else {
    filtered = masterItems.filter(function(i) { return i.caseStatus === 'รอส่งต่อสำนวน' || i.caseStatus === 'ส่งต่อสำเร็จแล้ว' || i.caseStatus === 'รายงานแล้ว'; });
  }

  if (countActive === 0 && currentTab === 'active') {
    tableCard.classList.add('hidden-table');
    return;
  }
  tableCard.classList.remove('hidden-table');

  if (filtered.length === 0) {
    tableCard.classList.add('hidden');
    emptyState.classList.remove('hidden');
    return;
  }
  tableCard.classList.remove('hidden');
  emptyState.classList.add('hidden');

  // Use DocumentFragment for performance
  var fragment = document.createDocumentFragment();
  filtered.forEach(function(item) {
    var tr = document.createElement('tr');
    var wColor = '';
    if (item.warrantStatus === 'รอเพิกถอน') wColor = 'red';
    else if (item.warrantStatus === 'เพิกถอน') wColor = 'gray';

    var isDone = item.caseStatus === 'ส่งต่อสำเร็จแล้ว';
    var doneMark = isDone ? ' ✓' : '';
    var caseBadge = badgeHtml(item.caseStatus);

    // Use data attributes for event delegation
    var actionHtml = '';
    if (isDone) {
      actionHtml = '<button class="btn-action amber disabled">เพิกถอน</button>';
    } else if (currentTab === 'active') {
      actionHtml = '<button class="btn-action amber" data-action="revoke" data-rowid="' + item.rowId + '">เพิกถอน</button>';
    } else {
      actionHtml = '<button class="btn-action green" data-action="forward" data-rowid="' + item.rowId + '">ส่งต่อ</button>' +
                   '<button class="btn-action blue" data-action="report" data-rowid="' + item.rowId + '">รายงาน</button>';
    }

    tr.innerHTML =
      '<td style="text-align:center;">' +
        '<div class="warrant-line"><span class="warrant-no">' + esc(item.warrantNumber) + doneMark + '</span><span class="warrant-status-tag ' + wColor + '">' + esc(item.warrantStatus) + '</span></div>' +
        '<div class="defendant-line">' + esc(item.defendantName) + '</div>' +
      '</td>' +
      '<td style="text-align:center;"><div style="font-weight:600;color:var(--text-main);font-size:12px;">' + esc(item.endReason) + '</div>' + (item.reasonDetail ? '<div style="font-size:11px;color:var(--text-dark);font-style:italic;">' + esc(item.reasonDetail) + '</div>' : '') + '</td>' +
      '<td style="text-align:center;">' + caseBadge + '</td>' +
      '<td style="text-align:right; white-space:nowrap;">' + actionHtml + '</td>';

    if (isDone) tr.style.opacity = '0.5';
    fragment.appendChild(tr);
  });

  list.replaceChildren(fragment);
}

function badgeHtml(s) {
  if (s === 'เสนอศาล') return '<span class="badge badge-amber">เสนอศาลแล้ว</span>';
  if (s === 'รอส่งต่อสำนวน') return '<span class="badge badge-indigo">รอส่งต่อสำนวน</span>';
  if (s === 'ส่งต่อสำเร็จแล้ว') return '<span class="badge badge-done">✓ ส่งต่อสำเร็จแล้ว</span>';
  if (s === 'รายงานแล้ว') return '<span class="badge badge-done">รายงานแล้ว</span>';
  return '<span class="badge badge-done">' + esc(s) + '</span>';
}

// =============================================================
// esc() — Proper XSS escaping
// =============================================================
function esc(s) {
  if (s == null) return '';
  return String(s).replace(/[&<>"']/g, function(m) {
    if (m === '&') return '&';
    if (m === '<') return '<';
    if (m === '>') return '>';
    if (m === '"') return '"';
    if (m === "'") return '&#39;';
    return m;
  });
}

// =============================================================
// Event Delegation for Action Buttons
// =============================================================
document.getElementById('itemsList').addEventListener('click', function(e) {
  var btn = e.target.closest('.btn-action:not(.disabled)');
  if (!btn) return;
  var action = btn.getAttribute('data-action');
  var rowId = btn.getAttribute('data-rowid');
  if (!action || !rowId) return;

  var titles = { revoke: 'เพิกถอนหมายจับ', forward: 'ส่งต่อสำนวน', report: 'รายงานผล' };
  var descs = {
    revoke: 'ยืนยันว่าศาลได้ลงนามเพิกถอนหมายจับนี้เรียบร้อยแล้ว?',
    forward: 'ยืนยันว่าส่งต่อสำนวนนี้เรียบร้อยแล้ว?',
    report: 'ยืนยันว่าทำรายงานผลสำนวนนี้เรียบร้อยแล้ว?'
  };
  showActionConfirm(titles[action] || action, descs[action] || 'ยืนยันการดำเนินการ?', function() {
    runAction(action, rowId);
  });
});

// =============================================================
// Consolidated Action Runner
// =============================================================
var actionMap = {
  revoke: { saveAction: 'markRevoked', msg: 'อัปเดตสถานะเป็น เพิกถอน สำเร็จ' },
  forward: { saveAction: 'markForwarded', msg: 'ส่งต่อสำนวนสำเร็จ' },
  report: { saveAction: 'report', msg: 'รายงานผลสำเร็จ' }
};

async function runAction(action, rowId) {
  if (isProcessing) return;
  var config = actionMap[action];
  if (!config) { showToast('ไม่พบ action: ' + action); return; }
  isProcessing = true;
  showLoading(true);
  try {
    await callGas("saveDB", { action: config.saveAction, data: { rowId: rowId } });
    showToast(config.msg);
    loadDashboard();
  } catch (err) {
    showToast("เกิดข้อผิดพลาด: " + (err.message || "กรุณาลองใหม่"));
  } finally {
    isProcessing = false;
    showLoading(false);
  }
}

// =============================================================
// Pull to Refresh
// =============================================================
var pullStartY = 0;
var pulling = false;

document.addEventListener('touchstart', function(e) {
  var scrollTop = document.documentElement.scrollTop || document.body.scrollTop;
  if (scrollTop === 0) {
    pullStartY = e.touches[0].clientY;
    pulling = true;
  }
}, { passive: true });

document.addEventListener('touchmove', function(e) {
  if (!pulling) return;
  var diff = e.touches[0].clientY - pullStartY;
  if (diff > 50) {
    document.getElementById('pullIndicator').classList.add('show');
    document.getElementById('pullIndicator').innerHTML = '<span class="spinner-small"></span> ปล่อยเพื่อรีโหลด...';
  } else {
    document.getElementById('pullIndicator').classList.remove('show');
  }
}, { passive: true });

document.addEventListener('touchend', function(e) {
  if (!pulling) return;
  pulling = false;
  var indicator = document.getElementById('pullIndicator');
  if (indicator.classList.contains('show')) {
    indicator.innerHTML = '<span class="spinner-small"></span> กำลังรีโหลดข้อมูล...';
    setTimeout(async function() {
      await loadDashboard();
      indicator.classList.remove('show');
      indicator.innerHTML = '<span class="spinner-small"></span> ปล่อยเพื่อรีโหลด...';
      showToast('รีเฟรชข้อมูลสำเร็จ');
    }, 300);
  }
}, { passive: true });

